---
import '../styles/global.css';
import SiteIcon from '../components/SiteIcon.astro';
import OpeningSequence from '../components/OpeningSequence.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = 'sqkstt777的个人博客',
  description = '记录工程实践、技术学习和长期写作的sqkstt777的个人博客。',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteTitle = title === 'sqkstt777的个人博客' ? title : `${title} | sqkstt777的个人博客`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const shouldRenderOpening = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href="/assets/wind-frames/saber-wind-00.webp" />
    <title>{siteTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Chakra+Petch:wght@400;500;600;700&family=Share+Tech+Mono&display=swap"
    />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="sqkstt777的个人博客 RSS" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    {shouldRenderOpening && <OpeningSequence />}
    <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
    <div class="space-bg" aria-hidden="true">
      <video
        class="saber-bg-video"
        id="saber-bg-video"
        muted
        loop
        playsinline
        preload="metadata"
        poster="/assets/wind-frames/saber-wind-00.webp"
      >
        <source data-src="/assets/saber1.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a class="brand" href="/">
            <span class="brand-mark"><SiteIcon name="brand" /></span>
            <span>sqkstt777</span>
          </a>
          <nav class="nav-links" aria-label="主导航">
            <a href="/" class:list={[Astro.url.pathname === '/' ? 'active' : '']}>首页</a>
            <a href="/categories/" class:list={[Astro.url.pathname.startsWith('/categories') ? 'active' : '']}>分类</a>
            <a href="/tags/" class:list={[Astro.url.pathname.startsWith('/tags') ? 'active' : '']}>标签</a>
            <a href="/about/" class:list={[Astro.url.pathname === '/about/' ? 'active' : '']}>关于</a>
            <a href="/rss.xml">RSS</a>
            <span class="nav-indicator" aria-hidden="true"></span>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <span>© {new Date().getFullYear()} sqkstt777</span>
          <span>Astro · GitHub Pages · RSS</span>
        </div>
      </footer>
    </div>
    <button class="back-to-top" id="back-to-top" aria-label="返回顶部">&uarr;</button>
    <button class="bg-audio-toggle" id="bg-audio-toggle" type="button" aria-label="开启背景音" title="开启背景音" hidden>
      <span aria-hidden="true">♪</span>
    </button>
    <script is:inline>
      (() => {
        const video = document.getElementById('saber-bg-video');
        const toggle = document.getElementById('bg-audio-toggle');
        if (!video || !toggle) return;

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) {
          video.pause();
          return;
        }

        const source = video.querySelector('source[data-src]');
        let loadStarted = false;
        let startTimer = 0;

        const loadVideo = () => {
          if (loadStarted || !source) return;
          source.src = source.dataset.src || '';
          loadStarted = true;
          video.load();
        };

        const setAudioState = (enabled) => {
          toggle.classList.toggle('active', enabled);
          toggle.setAttribute('aria-label', enabled ? '关闭背景音' : '开启背景音');
          toggle.title = enabled ? '关闭背景音' : '开启背景音';
        };

        const showToggle = () => {
          toggle.hidden = false;
        };

        const showVideo = () => {
          if (video.readyState < 2) return;
          document.body.classList.add('bg-video-live');
        };

        if (video.readyState >= 1) showToggle();
        else video.addEventListener('loadedmetadata', showToggle, { once: true });
        video.addEventListener('playing', showVideo);
        video.addEventListener('canplay', () => {
          if (!video.paused) showVideo();
        });

        video.muted = true;
        video.volume = 0.65;

        const startMuted = () => {
          loadVideo();
          video.muted = true;
          requestAnimationFrame(() => {
            video.play().then(showVideo).catch(() => {});
          });
        };

        const scheduleStart = (delay = 0) => {
          window.clearTimeout(startTimer);
          startTimer = window.setTimeout(startMuted, delay);
        };

        window.addEventListener('sqkstt:opening-start', () => {
          window.clearTimeout(startTimer);
          document.body.classList.remove('bg-video-live');
          if (!video.paused) video.pause();
        });

        toggle.addEventListener('click', async () => {
          loadVideo();
          const enableAudio = video.muted;
          video.muted = !enableAudio;
          try {
            await video.play();
            showVideo();
            setAudioState(enableAudio);
          } catch {
            video.muted = true;
            setAudioState(false);
          }
        });

        document.addEventListener('visibilitychange', () => {
          if (!loadStarted) return;
          if (document.hidden) {
            video.pause();
          } else {
            video.play().catch(() => {});
          }
        });

        const opening = document.getElementById('opening-sequence');
        const openingActive = opening && !opening.classList.contains('idle');
        if (openingActive) {
          window.addEventListener('sqkstt:opening-handoff', loadVideo, { once: true });
          window.addEventListener('sqkstt:opening-settled', () => scheduleStart(4200), { once: true });
        } else {
          const requestIdle = window.requestIdleCallback || ((cb) => window.setTimeout(cb, 900));
          requestIdle(() => scheduleStart(0));
        }
      })();
    </script>

    <script is:inline>
      (() => {
        // --- Reading progress + Back to top（合并为单个 rAF 节流的 scroll 处理器）---
        const bar = document.getElementById('reading-progress');
        const btn = document.getElementById('back-to-top');

        const updateProgress = () => {
          if (!bar) return;
          const h = document.documentElement;
          const pct = h.scrollHeight > h.clientHeight
            ? (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100
            : 0;
          bar.style.width = `${Math.min(100, Math.max(0, pct))}%`;
        };

        const toggleBtn = () => {
          if (btn) btn.classList.toggle('visible', window.scrollY > 400);
        };

        let scrollRaf = 0;
        const onScroll = () => {
          if (scrollRaf) return;
          scrollRaf = requestAnimationFrame(() => {
            scrollRaf = 0;
            updateProgress();
            toggleBtn();
          });
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        updateProgress();

        if (btn) {
          toggleBtn();
          btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        }

        // --- Code copy buttons ---
        document.querySelectorAll('.article-body pre').forEach(pre => {
          const wrap = document.createElement('div');
          wrap.className = 'code-block-wrapper';
          pre.replaceWith(wrap);
          wrap.appendChild(pre);
          const copyBtn = document.createElement('button');
          copyBtn.className = 'copy-button';
          copyBtn.textContent = '复制';
          copyBtn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              copyBtn.textContent = '已复制';
              copyBtn.classList.add('copied');
              setTimeout(() => { copyBtn.textContent = '复制'; copyBtn.classList.remove('copied'); }, 2000);
            } catch {
              copyBtn.textContent = '失败';
              setTimeout(() => { copyBtn.textContent = '复制'; }, 2000);
            }
          });
          wrap.appendChild(copyBtn);
        });

        // --- TOC + heading anchors + reading time ---
        const articleBody = document.querySelector('.article-body');
        const tocList = document.getElementById('toc-list');
        if (articleBody) {
          const chars = (articleBody.textContent ?? '').replace(/\s/g, '').length;
          const readingTime = `约 ${Math.max(1, Math.ceil(chars / 300))} 分钟阅读`;
          document.querySelectorAll('.reading-time').forEach(el => { el.textContent = readingTime; });

          const headings = articleBody.querySelectorAll('h2, h3');
          if (tocList && headings.length > 0) {
            const observer = new IntersectionObserver(entries => {
              entries.forEach(e => {
                const link = tocList.querySelector(`a[href="#${e.target.id}"]`);
                if (link) link.classList.toggle('active', e.isIntersecting);
              });
            }, { rootMargin: '-100px 0px -60% 0px' });

            headings.forEach((h, i) => {
              if (!h.id) h.id = `section-${i + 1}`;
              const anchor = document.createElement('a');
              anchor.href = `#${h.id}`;
              anchor.className = 'heading-anchor';
              anchor.textContent = '#';
              anchor.setAttribute('aria-hidden', 'true');
              h.prepend(anchor);

              const li = document.createElement('li');
              const a = document.createElement('a');
              a.href = `#${h.id}`;
              a.textContent = h.textContent ?? '';
              if (h.tagName === 'H3') a.classList.add('toc-h3');
              li.appendChild(a);
              tocList.appendChild(li);
              observer.observe(h);
            });
          }
        }

        // --- Copy article link ---
        const shareBtn = document.getElementById('toc-share-btn');
        if (shareBtn) {
          shareBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(window.location.href);
              shareBtn.classList.add('copied');
              const label = shareBtn.querySelector('.share-label');
              if (label) label.textContent = '已复制';
              setTimeout(() => {
                shareBtn.classList.remove('copied');
                if (label) label.textContent = '复制链接';
              }, 2000);
            } catch {
              // fallback silently
            }
          });
        }
      })();
    </script>
    <script is:inline>
      (() => {
        document.querySelectorAll('.post-card').forEach((card) => {
          card.classList.add('glow-border');
          if (!card.querySelector(':scope > .card-glow')) {
            const glow = document.createElement('span');
            glow.className = 'card-glow';
            glow.setAttribute('aria-hidden', 'true');
            card.prepend(glow);
          }
        });

        const counters = document.querySelectorAll('[data-count]');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) {
          counters.forEach((el) => { el.textContent = el.getAttribute('data-count') || '0'; });
          return;
        }

        // 滚动渐入：把目标区块标记为 .reveal，进入视口加 .in-view，按 DOM 顺序错峰
        const groups = [
          '.post-card',
          '.stat-card',
          '.directory-tag',
          '.content-heading',
          '.directory-head',
          '.home-sidebar',
          '.toc-panel',
        ];

        // 先给目标加 .reveal
        const targets = [];
        let revealObserver = null;
        groups.forEach((sel) => {
          document.querySelectorAll(sel).forEach((el) => {
            el.classList.add('reveal');
            targets.push(el);
          });
        });

        targets
          .sort((a, b) => {
            if (a === b) return 0;
            return a.compareDocumentPosition(b) & Node.DOCUMENT_POSITION_FOLLOWING ? -1 : 1;
          })
          .forEach((el, i) => {
            el.style.setProperty('--reveal-d', Math.min(i, 6) * 70 + 'ms');
        });

        if (!('IntersectionObserver' in window) || !targets.length) {
          targets.forEach((el) => el.classList.add('in-view'));
        }
        if ('IntersectionObserver' in window && targets.length) {
          revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                revealObserver.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

          targets.forEach((el) => revealObserver.observe(el));
        }

        const primeOpeningViewport = () => {
          const bottom = window.innerHeight * 1.12;
          targets.forEach((el) => {
            if (el.classList.contains('in-view')) return;
            const rect = el.getBoundingClientRect();
            if (rect.bottom >= -80 && rect.top <= bottom) {
              el.style.setProperty('--reveal-d', '0ms');
              el.classList.add('in-view');
              revealObserver?.unobserve(el);
            }
          });
        };

        window.addEventListener('sqkstt:opening-handoff', () => {
          requestAnimationFrame(primeOpeningViewport);
        }, { once: true });

        // 统计数字递增：进入视口时从 0 递增到 data-count（easeOutCubic）
        const runCount = (el) => {
          const target = parseInt(el.getAttribute('data-count') || '0', 10);
          if (!target || target <= 0) { el.textContent = String(target); return; }
          const duration = 1200;
          const start = performance.now();
          const tick = (now) => {
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = String(target);
          };
          requestAnimationFrame(tick);
        };

        if (!('IntersectionObserver' in window) || !counters.length) {
          counters.forEach((el) => { el.textContent = el.getAttribute('data-count') || '0'; });
        } else {
          const cio = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                runCount(entry.target);
                cio.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });
          counters.forEach((el) => cio.observe(el));
        }

        // 导航滑动光条：跟随 active 项，hover 其他项时跟随
        const navLinks = document.querySelector('.nav-links');
        const navIndicator = document.querySelector('.nav-indicator');
        if (navLinks && navIndicator) {
          const links = navLinks.querySelectorAll('a');
          const placeIndicator = (el) => {
            if (!el) { navIndicator.classList.remove('visible'); return; }
            const navRect = navLinks.getBoundingClientRect();
            const rect = el.getBoundingClientRect();
            navIndicator.style.width = rect.width + 'px';
            navIndicator.style.transform = `translateX(${rect.left - navRect.left}px)`;
            navIndicator.classList.add('visible');
          };

          const activeLink = navLinks.querySelector('a.active');
          requestAnimationFrame(() => placeIndicator(activeLink));

          links.forEach((link) => {
            link.addEventListener('pointerenter', () => placeIndicator(link));
          });
          navLinks.addEventListener('pointerleave', () => placeIndicator(activeLink));
          window.addEventListener('resize', () => placeIndicator(activeLink));
        }
      })();
    </script>
  </body>
</html>
