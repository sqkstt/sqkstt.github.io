---
import '../styles/global.css';
import SiteIcon from '../components/SiteIcon.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = '中文技术博客',
  description = '记录工程实践、技术学习和长期写作的中文技术博客。',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteTitle = title === '中文技术博客' ? title : `${title} | 中文技术博客`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="中文技术博客 RSS" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="space-bg" aria-hidden="true">
      <span class="meteor meteor-one"></span>
      <span class="meteor meteor-two"></span>
      <span class="meteor meteor-three"></span>
      <span class="meteor meteor-four"></span>
      <span class="meteor meteor-five"></span>
      <span class="meteor meteor-six"></span>
      <span class="meteor meteor-seven"></span>
      <span class="meteor meteor-eight"></span>
      <span class="meteor meteor-nine"></span>
      <span class="meteor meteor-ten meteor-pink"></span>
      <span class="meteor meteor-eleven meteor-violet"></span>
      <span class="meteor meteor-twelve meteor-short"></span>
      <span class="meteor meteor-thirteen meteor-long"></span>
      <span class="meteor meteor-fourteen meteor-pink"></span>
      <span class="meteor meteor-fifteen meteor-violet"></span>
      <span class="meteor meteor-sixteen meteor-short"></span>
    </div>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a class="brand" href="/">
            <span class="brand-mark"><SiteIcon name="brand" /></span>
            <span>sqkstt.log</span>
          </a>
          <nav class="nav-links" aria-label="主导航">
            <a href="/">首页</a>
            <a href="/categories/">分类</a>
            <a href="/tags/">标签</a>
            <a href="/about/">关于</a>
            <a href="/rss.xml">RSS</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <span>© {new Date().getFullYear()} sqkstt.log</span>
          <span>Astro · GitHub Pages · RSS</span>
        </div>
      </footer>
    </div>
    <div class="corner-pet" id="corner-pet" aria-hidden="true">
      <div class="corner-pet-inner">
        <img src="/assets/codex-pet-mascot.png" alt="" draggable="false" />
      </div>
    </div>
    <script is:inline>
      (() => {
        const pet = document.getElementById('corner-pet');
        if (!pet) return;

        const storageKey = 'sqkstt.cornerPet.position';
        const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

        const place = (x, y) => {
          const rect = pet.getBoundingClientRect();
          const nextX = clamp(x, 0, window.innerWidth - rect.width);
          const nextY = clamp(y, 0, window.innerHeight - rect.height);
          pet.style.left = `${nextX}px`;
          pet.style.top = `${nextY}px`;
          pet.style.right = 'auto';
          pet.style.bottom = 'auto';
        };

        const saved = localStorage.getItem(storageKey);
        if (saved) {
          try {
            const { x, y } = JSON.parse(saved);
            requestAnimationFrame(() => place(Number(x), Number(y)));
          } catch {
            localStorage.removeItem(storageKey);
          }
        }

        let drag = null;
        pet.addEventListener('pointerdown', (event) => {
          if (event.button !== undefined && event.button !== 0) return;
          const rect = pet.getBoundingClientRect();
          drag = {
            offsetX: event.clientX - rect.left,
            offsetY: event.clientY - rect.top,
          };
          pet.classList.add('dragging');
          pet.setPointerCapture?.(event.pointerId);
          event.preventDefault();
        });

        pet.addEventListener('pointermove', (event) => {
          if (!drag) return;
          place(event.clientX - drag.offsetX, event.clientY - drag.offsetY);
        });

        const endDrag = (event) => {
          if (!drag) return;
          drag = null;
          pet.classList.remove('dragging');
          pet.releasePointerCapture?.(event.pointerId);
          const rect = pet.getBoundingClientRect();
          localStorage.setItem(storageKey, JSON.stringify({ x: rect.left, y: rect.top }));
        };

        pet.addEventListener('pointerup', endDrag);
        pet.addEventListener('pointercancel', endDrag);
        window.addEventListener('resize', () => {
          const rect = pet.getBoundingClientRect();
          if (getComputedStyle(pet).display !== 'none') place(rect.left, rect.top);
        });
      })();
    </script>
  </body>
</html>
