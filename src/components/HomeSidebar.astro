---
interface Props {
  categories: string[];
}

const { categories } = Astro.props;
---

<aside class="home-sidebar">
  <!-- Author card -->
  <div class="toc-section">
    <div class="home-author">
      <img
        src="/assets/kaguya-tako-idle-frame.webp"
        alt="Mascot"
        class="home-author-img"
        draggable="false"
      />
      <div class="home-author-text">
        <strong>sqkstt777</strong>
        <p>游戏引擎开发学习者。</p>
      </div>
    </div>
    <a href="/about/" class="home-side-link">了解更多 &rarr;</a>
  </div>

  <hr class="toc-divider" />

  <!-- Categories -->
  <h3 class="toc-heading">分类</h3>
  {
    categories.length > 0 ? (
      <div class="toc-tags">
        {categories.map((category) => (
          <a class="tag" href={`/categories/${encodeURIComponent(category)}/`}>{category}</a>
        ))}
      </div>
    ) : (
      <p style="color:var(--muted);font-size:12px;margin:4px 0 0;">
        发布文章后，分类会自动出现。
      </p>
    )
  }
  <a href="/categories/" class="home-side-link" style="margin-top:8px;">浏览全部分类 &rarr;</a>

  <hr class="toc-divider" />

  <!-- RSS subscription -->
  <div class="home-rss">
    <div class="home-rss-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
    </div>
    <div class="home-rss-text">
      <strong>RSS 订阅</strong>
      <p>第一时间获取最新文章</p>
    </div>
  </div>
  <a href="/rss.xml" class="home-side-link home-side-primary"><span class="home-side-label">订阅 RSS &rarr;</span></a>

  <hr class="toc-divider" />

  <!-- Social platform links -->
  <h3 class="toc-heading">社交平台</h3>
  <div class="social-badges">
    <a href="https://steamcommunity.com/id/yourprofile" target="_blank" rel="noopener noreferrer" class="social-badge">Steam</a>
    <a href="https://space.bilibili.com/yourid" target="_blank" rel="noopener noreferrer" class="social-badge">Bilibili</a>
    <a href="https://bgm.tv/user/yourname" target="_blank" rel="noopener noreferrer" class="social-badge">Bangumi</a>
    <a href="https://leetcode.cn/u/yourname" target="_blank" rel="noopener noreferrer" class="social-badge">LeetCode</a>
  </div>
</aside>
