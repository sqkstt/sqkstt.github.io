---
interface Props {
  name: 'brand' | 'pen' | 'category' | 'tag' | 'deploy' | 'empty' | 'owl';
}

const { name } = Astro.props;
---

<svg class="icon-glyph" viewBox="0 0 64 64" aria-hidden="true">
  {
    name === 'brand' && (
      <>
        <path d="M32 10l5.8 15.2L53 31.8l-15.2 6.4L32 54l-5.8-15.8L11 31.8l15.2-6.6L32 10z" />
        <path d="M32 22l2.4 6.2L40 31.8l-5.6 2.4L32 40l-2.4-5.8L24 31.8l5.6-3.6L32 22z" />
      </>
    )
  }
  {
    name === 'pen' && (
      <>
        <path d="M18 45l4.6-14.8L39.8 13a6.4 6.4 0 019 9L31.6 39.2 18 45z" />
        <path d="M36.4 17.4l8.2 8.2" />
        <path d="M22.6 31.6l8 8" />
      </>
    )
  }
  {
    name === 'category' && (
      <>
        <path d="M16 17h16l5 6h11v28H16V17z" />
        <path d="M22 31h26" />
        <path d="M22 39h18" />
      </>
    )
  }
  {
    name === 'tag' && (
      <>
        <path d="M15 18v15.2L32.8 51 51 32.8 33.2 15H18a3 3 0 00-3 3z" />
        <path d="M25 25h.1" />
        <path d="M32 25h14" />
      </>
    )
  }
  {
    name === 'deploy' && (
      <>
        <path d="M32 9v25" />
        <path d="M22 24l10 10 10-10" />
        <path d="M17 41c2.2 7.8 8.2 12 15 12s12.8-4.2 15-12" />
        <path d="M20 17a22 22 0 0124 0" />
      </>
    )
  }
  {
    name === 'empty' && (
      <>
        <path d="M32 12l4.2 11.8L48 28l-11.8 4.2L32 52l-4.2-19.8L16 28l11.8-4.2L32 12z" />
        <path d="M18 44h10" />
        <path d="M46 18h-8" />
      </>
    )
  }
  {
    name === 'owl' && (
      <>
        <path d="M17 25c0-10 7-16 15-16s15 6 15 16v11c0 11-7 19-15 19s-15-8-15-19V25z" />
        <path d="M19 19l-6-8 12 4" />
        <path d="M45 19l6-8-12 4" />
        <path d="M23 29a7 7 0 1014 0 7 7 0 10-14 0" />
        <path d="M31 29a7 7 0 1014 0 7 7 0 10-14 0" />
        <path d="M32 33l-4 6h8l-4-6z" />
        <path d="M24 46c4 4 12 4 16 0" />
      </>
    )
  }
</svg>
