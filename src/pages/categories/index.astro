---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const categoryCounts = posts.reduce<Map<string, number>>((counts, post) => {
  counts.set(post.data.category, (counts.get(post.data.category) ?? 0) + 1);
  return counts;
}, new Map());
const categories = [...categoryCounts.entries()].sort(([a], [b]) => a.localeCompare(b, 'zh-CN'));
---

<BaseLayout title="分类" description="按分类浏览中文技术博客文章。">
  <section class="container page-intro decorated-intro page-hero">
    <span class="page-symbol">◇</span>
    <h1>分类</h1>
    <p>每篇文章归入一个主分类，标签用于补充更细的主题。</p>
  </section>

  <section class="container directory-panel" aria-label="分类列表">
    <div class="directory-head">
      <h2>主题目录</h2>
      <p>发布文章后，分类会按名称自动整理在这里。</p>
    </div>
    <div class="tag-grid">
      {
        categories.length > 0
          ? categories.map(([category, count]) => <a class="tag directory-tag" href={`/categories/${encodeURIComponent(category)}/`}>{category} · {count}</a>)
          : (
              <div class="empty-state rich-empty wide-empty">
                <span class="empty-icon">◇</span>
                <div>
                  <strong>还没有可浏览的分类</strong>
                  <p>等第一篇公开文章发布后，这里会自动出现对应分类。</p>
                </div>
              </div>
            )
      }
    </div>
  </section>
</BaseLayout>
