---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = posts.reduce<Map<string, number>>((counts, post) => {
  post.data.tags.forEach((tag) => counts.set(tag, (counts.get(tag) ?? 0) + 1));
  return counts;
}, new Map());
const tags = [...tagCounts.entries()].sort(([a], [b]) => a.localeCompare(b, 'zh-CN'));
---

<BaseLayout title="标签" description="按标签浏览中文技术博客文章。">
  <section class="container page-intro">
    <h1>标签</h1>
    <p>按主题整理文章，方便回看同一类问题的连续记录。</p>
  </section>

  <section class="container tag-grid" aria-label="标签列表">
    {
      tags.length > 0
        ? tags.map(([tag, count]) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag} · {count}</a>)
        : <p class="empty-state">还没有可浏览的标签。</p>
    }
  </section>
</BaseLayout>
